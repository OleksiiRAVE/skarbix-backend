NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,https://app.skarbix.xyz,https://dev-app.skarbix.xyz

# Supabase frontend-safe URL plus backend-only service role key.
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Optional but recommended in production. When absent, the backend derives
# a stable encryption key from SUPABASE_SERVICE_ROLE_KEY.
MONOBANK_TOKEN_ENCRYPTION_KEY=replace-with-random-32-plus-character-secret

# Optional: set later when JWT verification is moved fully local.
# SUPABASE_JWT_SECRET=replace-with-jwt-secret
